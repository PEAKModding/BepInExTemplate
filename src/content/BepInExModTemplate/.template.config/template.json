{
    "$schema": "http://json.schemastore.org/template",
    "author": "_TemplateRepoAuthorNoSpaces_",
    "classifications": [
        "BepInEx", "Plugin", "Mod"
    ],
    "identity": "_TemplateRepoAuthorNoSpaces_._TemplatePackageNameNoSpaces_",
    "name": "_GameName_ BepInEx Plugin",
    "shortName": "_GameNameShortNoSpacesLowercase_mod",
    "tags": {
        "language": "C#",
        "type": "project"
    },
    "sourceName": "BepInExModTemplate",
    "defaultName": "MyPlugin",
    "symbols": {
        "guid": {
            "type": "parameter",
            "displayName": "GUID",
            "description": "The global identifier for your mod. Example: AuthorName.ModName",
            "datatype": "text",
            "replaces": "_Guid_",
            "isRequired": "true"
        },
        "ts-team": {
            "type": "parameter",
            "displayName": "Thunderstore Team",
            "description": "The thunderstore team to publish this package under.",
            "datatype": "text",
            "replaces": "_ts-team_",
            "defaultValue": "TODO_team_name_here"
        },
        "no-tutorial": {
            "type": "parameter",
            "displayName": "No Tutorial",
            "description": "If true, tutorial comments will not be present.",
            "datatype": "bool",
            "defaultValue": "false"
        },
        "library": {
            "type": "parameter",
            "displayName": "Library",
            "description": "If true, NuGet metadata is included in the project.",
            "datatype": "bool",
            "defaultValue": "false"
        },
        "inverted-gitignore": {
            "type": "parameter",
            "displayName": "Inverted gitignore",
            "description": "Gitignore ignores everything and specifies what to include.",
            "datatype": "bool",
            "defaultValue": "false"
        },
        // __TEMPLATE_CONFIG_IF(GameLibsAvailable)__
        "github-workflow": {
            "type": "parameter",
            "displayName": "GitHub Workflow",
            "description": "Use GitHub actions for publishing & git tags for versioning.",
            "datatype": "bool",
            "defaultValue": "false"
        }
        // __TEMPLATE_CONFIG_ENDIF__
    },
    "sources": [
        {
            "modifiers": [
                {
                    // __TEMPLATE_CONFIG_IF(GameLibsAvailable)__
                    "condition": "!(github-workflow)",
                    // __TEMPLATE_CONFIG_ENDIF__
                    "exclude": [
                        ".github/**"
                    ]
                }
            ]
        }
    ]
}
